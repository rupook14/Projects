import re
import numpy as np

def parse_weather_by_year(year):
    html_file = f"weather_data/toronto_weather_{year}.html"
    csv_file = f"toronto_weather_{year}.csv"

   
    with open(html_file, "r", encoding="utf-8") as f:
        html = f.read()

    
    pattern = re.findall(
        r"<a href='/cities/toronto/day/([a-z]+)-(\d+)'>.*?</a>.*?"
        r"<td class='text-right[^']*'>([^<]+)</td>.*?"
        r"<td class='text-right[^']*'>([^<]+)</td>.*?"
        r"<td class='text-right[^']*'>([^<]+)</td>",
        html,
        re.S
    )

    print(f"Number of records found: {len(pattern)}")

    with open(csv_file, "w", encoding="utf-8") as f:
        f.write("city,day_of_year,month,day_of_month,year,high_temp,low_temp,precipitation\n")

        day_of_year = 1

        for match in pattern:
            month = match[0].lower()
            day = int(match[1])
            high = match[2].strip()
            low = match[3].strip()
            precip = match[4].strip()

            high = float(high) if high != "n/a" else np.nan
            low = float(low) if low != "n/a" else np.nan
            precip = float(precip) if precip != "n/a" else np.nan

            f.write(f"Toronto,{day_of_year},{month},{day},{year},{high},{low},{precip}\n")
            day_of_year += 1

    data = np.genfromtxt(csv_file, delimiter=",", names=True, dtype=None, encoding="utf-8")

    print(f"{'':4}{'city':15}{'day_of_year':11}{'month':11}{'day_of_month':12}{'year':6}{'high_temp':10}{'low_temp':10}{'precipitation':14}")
    for i, row in enumerate(data):
        print(f"{i:<4}{row['city']:<15}{row['day_of_year']:>11}{row['month']:>11}{row['day_of_month']:>12}{row['year']:>6}{row['high_temp']:>10}{row['low_temp']:>10}{row['precipitation']:>14}")

    print("\nStatistics:")
    print(f"High Temp -> Mean: {np.nanmean(data['high_temp']):.2f}, Min: {np.nanmin(data['high_temp'])}, Max: {np.nanmax(data['high_temp'])}")
    print(f"Low Temp  -> Mean: {np.nanmean(data['low_temp']):.2f}, Min: {np.nanmin(data['low_temp'])}, Max: {np.nanmax(data['low_temp'])}")
    print(f"Precip    -> Mean: {np.nanmean(data['precipitation']):.2f}, Min: {np.nanmin(data['precipitation'])}, Max: {np.nanmax(data['precipitation'])}")
